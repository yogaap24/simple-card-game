{
  "name": "card-game-bisindo",
  "version": "1.0.0",
  "description": "Multiplayer Indonesian word card game",
  "main": "index.js",
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install"
  },
  "keywords": ["card-game", "multiplayer", "indonesian", "websocket"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

